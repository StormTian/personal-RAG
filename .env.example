# Environment Configuration Template
# 
# This file serves as a template for environment-specific configurations.
# Copy the appropriate file to .env and customize for your environment.
#
# Available environments:
# - .env.development (development settings)
# - .env.production (production settings)
# - .env.testing (testing settings)

# ============================================================
# Required Variables
# ============================================================

# Application Environment
APP_ENV=development

# ============================================================
# Optional Variables
# ============================================================

# OpenAI API Configuration
# Set these to enable cloud-based embeddings and reranking
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_RERANK_MODEL=gpt-3.5-turbo

# Application Settings
# DEBUG=true
# PORT=8000
# HOST=127.0.0.1

# Logging
# LOG_LEVEL=INFO
# LOG_FORMAT=standard

# Document Processing
# CHUNK_SIZE=240
# CHUNK_OVERLAP=1
# TOP_K=3

# Security
# SECRET_KEY=your-secret-key-here
# ALLOWED_HOSTS=localhost,127.0.0.1
# RAG_API_KEY=your-api-key-for-external-access
# RAG_ENABLE_AUTH=false
# RAG_ENABLE_RATE_LIMIT=true
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# RATE_LIMIT_REQUESTS_PER_MINUTE=100
# AUDIT_LOG_ENABLED=true
# CSP_ENABLED=true

# ============================================================
# Advanced Settings
# ============================================================

# Performance Tuning
# WORKERS=4
# THREADS=2
# MAX_REQUESTS=1000

# Monitoring & Alerting
# ENABLE_METRICS=true
# METRICS_PORT=9090
# ALERT_EMAIL=admin@example.com

# Backup
# BACKUP_ENABLED=true
# BACKUP_INTERVAL=daily
